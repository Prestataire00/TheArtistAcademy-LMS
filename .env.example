# ─── SUPABASE ──────────────────────────────────────────────────────────────────
# Transaction pooler (port 6543) — utilisé par Prisma pour les requêtes
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) — utilisé par Prisma pour les migrations
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"


# ─── JWT INTERNE (LMS) ─────────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production-min-32-chars"
JWT_EXPIRES_IN="8h"

# ─── SSO DENDREO ────────────────────────────────────────────────────────────────
# Clé publique RSA au format PEM (RS256) fournie par Dendreo
DENDREO_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nVOTRE_CLE_PUBLIQUE_ICI\n-----END PUBLIC KEY-----"
DENDREO_JWT_ALGORITHM="RS256"
DENDREO_JWT_EXPIRY_TOLERANCE_SECONDS=30

# ─── BUNNY.NET ──────────────────────────────────────────────────────────────────
BUNNY_API_KEY="votre-bunny-api-key"
BUNNY_LIBRARY_ID="votre-library-id"
BUNNY_STREAM_HOSTNAME="vz-xxxxxxxx.b-cdn.net"
BUNNY_STORAGE_ZONE="votre-storage-zone"
BUNNY_STORAGE_API_KEY="votre-storage-api-key"
BUNNY_CDN_HOSTNAME="votre-cdn.b-cdn.net"
BUNNY_SIGNED_URL_SECRET="votre-secret-signed-url"
BUNNY_WEBHOOK_SECRET="votre-webhook-secret"

# ─── EMAIL (BREVO) ───────────────────────────────────────────────────────────────
BREVO_API_KEY="votre-brevo-api-key"
EMAIL_FROM_ADDRESS="noreply@theartistacademy.fr"
EMAIL_FROM_NAME="The Artist Academy"

# ─── APPLICATION ────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3001
API_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"
CORS_ORIGIN="http://localhost:3000"

# ─── WEBHOOKS ────────────────────────────────────────────────────────────────────
DENDREO_WEBHOOK_URL="https://api.dendreo.com/webhook/lms/progress"
DENDREO_WEBHOOK_SECRET="votre-secret-webhook-dendreo"
