# ─── SUPABASE ──────────────────────────────────────────────────────────────────
# Transaction pooler (port 6543) — utilisé par Prisma pour les requêtes
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) — utilisé par Prisma pour les migrations
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"


# ─── JWT INTERNE (LMS) ─────────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production-min-32-chars"
JWT_EXPIRES_IN="8h"

# ─── SSO DENDREO ────────────────────────────────────────────────────────────────
# Secret partagé HS256 pour vérifier le JWT SSO Dendreo
DENDREO_JWT_SECRET="votre-secret-jwt-dendreo"
DENDREO_JWT_EXPIRY_TOLERANCE_SECONDS=30

# ─── SUPABASE STORAGE ───────────────────────────────────────────────────────────
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="votre-service-role-key"
SUPABASE_STORAGE_BUCKET="videos"
SUPABASE_RESOURCES_BUCKET="resources"
SUPABASE_SIGNED_URL_EXPIRES_IN=7200

# ─── EMAIL (RESEND) ──────────────────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM_ADDRESS="noreply@the-artist-academy.fr"
EMAIL_FROM_NAME="The Artist Academy"
REMINDER_DELAY_DAYS=7

# ─── APPLICATION ────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3001
API_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"
CORS_ORIGIN="http://localhost:3000"

# URL absolue de l'API, exposée au client Next (rewrites + uploads multipart
# qui bypassent le proxy Next pour éviter les limites de taille du dev server).
# En prod : pointe sur l'URL du service API Railway.
NEXT_PUBLIC_API_URL="http://localhost:3001"

# ─── DENDREO (Extranet participant) ──────────────────────────────────────────────
#NEXT_PUBLIC_DENDREO_EXTRANET_URL="https://[votre-compte].dendreo.com/extranet"
#NEXT_PUBLIC_DENDREO_DASHBOARD_URL="https://extranet-the-artist-academy-sandbox.dendreo.com/participants/dashboard"
NEXT_PUBLIC_DENDREO_EXTRANET_URL="https://extranet-the-artist-academy-sandbox.dendreo.com/participants/dashboard
# ─── DENDREO INTEGRATION ─────────────────────────────────────────────────────────
DENDREO_WEBHOOK_SECRET="votre-secret-webhook-dendreo"
DENDREO_API_KEY="votre-api-key-dendreo"
DENDREO_TENANT_ID="votre-tenant-id-dendreo"
